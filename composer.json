{
    "name": "ballspins/nik-parser",
    "description": "Parser NIK Indonesia dengan arsitektur Disk-Backed Binary Search. Dirancang khusus untuk efisiensi memori konstan (< 4 MB) dan skalabilitas maksimal, tanpa ketergantungan library tambahan.",
    "type": "library",
    "license": "MIT",
    "keywords": ["nik", "parser", "indonesia", "ktp", "binary-search", "high-performance"],
    "authors": [
        {
            "name": "ballspins"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "12.5.x-dev"
    },
    "autoload": {
        "psr-4": {
            "Ballspins\\NikParser\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "php vendor/phpunit/phpunit/phpunit --testdox",
        "convert": "php utility/convert.php",
        "validate-data": "php utility/validate.php",
        "benchmark": "php utility/benchmark.php"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpunit/phpunit": true
        }
    },
    "support": {
        "issues": "https://github.com/BallSpins/nik-parser-php/issues",
        "source": "https://github.com/BallSpins/nik-parser-php"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
